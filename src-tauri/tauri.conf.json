{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XiLuoLin",
  "version": "0.1.0",
  "identifier": "com.xiluolin.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "XiLuoLin",
        "width": 1000,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "opener": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
