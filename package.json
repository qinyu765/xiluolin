{
  "name": "xiluolin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.mjs\" \"*.{ts,json,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.mjs\" \"*.{ts,json,mjs}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "bindings:generate": "node scripts/bindings.mjs",
    "bindings:check": "node scripts/bindings.mjs --check",
    "build:frontend": "node scripts/build.mjs",
    "build": "pnpm typecheck && pnpm build:frontend",
    "check:frontend": "pnpm format:check && pnpm lint && pnpm test && pnpm build",
    "check:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check && cargo check --manifest-path src-tauri/Cargo.toml && cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "pnpm check:frontend && pnpm bindings:check && pnpm check:rust",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:macos:arm64": "MACOSX_DEPLOYMENT_TARGET=13.0 CMAKE_OSX_DEPLOYMENT_TARGET=13.0 pnpm tauri build --target aarch64-apple-darwin --bundles app,dmg"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.26.2",
  "description": "开源 AI 语音输入助手，将语音转化为可直接使用的办公、写作和编程文本。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qinyu765/xiluolin.git"
  },
  "bugs": {
    "url": "https://github.com/qinyu765/xiluolin/issues"
  },
  "homepage": "https://github.com/qinyu765/xiluolin#readme"
}
